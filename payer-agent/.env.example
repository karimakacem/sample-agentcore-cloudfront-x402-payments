# AWS Configuration
AWS_REGION=us-west-2

# AgentCore Runtime Configuration
# Get this ARN after deploying the agent to AgentCore Runtime:
#   python scripts/deploy_to_agentcore.py
#   # Look for output: AgentRuntimeArn = arn:aws:bedrock-agentcore:us-west-2:123456789012:runtime/...
AGENT_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-west-2:123456789012:runtime/your-runtime-id

# Bedrock Model ID (for local development without AgentCore Runtime)
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# AgentCore Payments Configuration
# Set up resources using the AWS CLI or boto3 — see:
# https://docs.aws.amazon.com/bedrock-agentcore/latest/devguide/payments.html
MANAGER_ARN=arn:aws:bedrock-agentcore:us-west-2:123456789012:payment-manager/your-manager-id
PAYMENT_SESSION_ID=your-session-id
PAYMENT_INSTRUMENT_ID=your-instrument-id
PROCESS_PAYMENT_ROLE_ARN=arn:aws:iam::123456789012:role/AgentCorePaymentsProcessPaymentRole
USER_ID=test-user-12345
# Optional: Override the data plane endpoint (boto3 auto-resolves from region)
# DP_ENDPOINT=https://bedrock-agentcore.us-west-2.amazonaws.com

# Seller API (CloudFront distribution URL after deployment)
# Get this URL after deploying seller-infrastructure:
#   cd seller-infrastructure && cdk deploy
#   # Look for output: X402DistributionUrl = https://dXXXXXXXXXXXXX.cloudfront.net
SELLER_API_URL=https://your-cloudfront-distribution.cloudfront.net

# API Server Configuration (for web UI backend)
API_PORT=8080

# OpenTelemetry Configuration
# OTLP endpoint for trace export (e.g., AWS X-Ray OTLP endpoint or local collector)
# Leave empty to disable OTLP export
OTEL_EXPORTER_OTLP_ENDPOINT=

# Set to "true" to also export traces to console (useful for debugging)
OTEL_CONSOLE_EXPORT=false

# Environment name for trace metadata
ENVIRONMENT=development
